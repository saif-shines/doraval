    --home-graphite-ink: oklch(92% 0.01 260);
    --home-graphite-muted: oklch(70% 0.015 260);
    --home-rule-2: oklch(30% 0.02 258);
    --home-space-md: 1.5rem;
    --home-space-lg: 2rem;
    --home-space-xl: 3rem;
    --home-space-2xl: 4.5rem;
    --home-ease-out: cubic-bezier(0.16, 1, 0.3, 1);

    max-width: 72rem;
    margin-inline: auto;
    padding-inline: var(--home-space-md);
  }

