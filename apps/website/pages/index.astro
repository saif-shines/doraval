    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.05;
    font-size: clamp(2rem, 4vw + 1rem, 3.25rem);
    overflow-wrap: anywhere;
    min-width: 0;
    margin: 0 0 var(--home-space-md);
  }

