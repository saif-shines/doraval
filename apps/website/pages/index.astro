---
// Hallmark · genre: modern-minimal · macrostructure: Workbench · theme: Cobalt
// Single fold: hero only — skill install first, then dora on the project
import PageLayout from "blume/components/layout/PageLayout.astro";
import CodeBlock from "blume/components/content/CodeBlock.astro";
import data from "blume:data";
import Footer from "./_home/Footer.astro";

const { config } = data;

/** Compact terminal for first-fold height. */
const heroDemo = `# 1) install the doraval skill
npx skills add saif-shines/doraval

# 2) review this project
npx @hacksmith/doraval

$ dora
  Health  ✗ .claude/skills/deploy  Missing description
  Next    1. dora fix …  2. dora review …`;
---

<PageLayout
  site={{ title: config.title, description: config.description }}
  logo={config.logo}
  favicon={config.favicon}
  banner={config.banner}
  analytics={config.analytics}
  navigation={data.navigation}
  fontCssVars={data.fontCssVars}
  themeMode={config.theme.mode}
  searchEnabled={config.search.enabled}
  siteUrl={config.site}
  ogEnabled={config.og.enabled}
  page={{
    title: `${config.title}: ${config.description}`,
    description: config.description,
    route: "/",
  }}
>
  <div class="home">
    <section class="hero">
      <div class="hero__copy reveal">
        <p class="home-eyebrow">FOR CODING AGENTS</p>
        <h1 class="hero__title">Make agent context work on every try</h1>
        <h2 class="hero__subtitle">
          Context engineering toolkit — scan, review, fix, and remember
        </h2>
        <p class="hero__lede">
          Broken skills, silent Claude-vs-Cursor contradictions, decisions that
          vanish next session. Install the skill first, then check with{" "}
          <strong>dora</strong>.
        </p>
        <div class="hero__ctas">
          <a class="btn btn--primary" href="/get-started/installation/"
            >Install the skill</a
          >
          <a class="btn btn--ghost" href="/get-started/quickstart/"
            >Review my context</a
          >
        </div>
        <p class="hero__note">
          doraval · <em>dor-uh-val</em> · Doraemon + eval ·{" "}
          <a href="/get-started/">Docs</a>
        </p>
      </div>
      <div class="hero__demo reveal">
        <CodeBlock code={heroDemo} lang="bash" title="terminal" />
      </div>
    </section>
  </div>

  <Footer slot="footer" title={config.title} description={config.description} />
</PageLayout>

<style>
  .home {
    --home-space-md: 1.25rem;
    --home-space-lg: 1.5rem;
    --home-space-xl: 2rem;
    --home-ease-out: cubic-bezier(0.16, 1, 0.3, 1);

    max-width: 72rem;
    margin-inline: auto;
    padding-inline: var(--home-space-md);
    /* fill fold under sticky header (~4rem) + compact footer */
    min-height: calc(100dvh - 7.5rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .home-eyebrow {
    margin: 0 0 0.65rem;
    font-family: var(--blume-font-mono);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--blume-accent);
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--home-space-xl);
    padding-block: var(--home-space-lg);
    align-items: center;
  }

  @media (min-width: 768px) {
    .hero {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: var(--home-space-xl);
    }
  }

  .hero__title {
    font-family: var(--blume-font-display);
    font-weight: 600;
    letter-spacing: -0.02em;
    line-height: 1.05;
    font-size: clamp(1.75rem, 3.2vw + 0.75rem, 2.75rem);
    overflow-wrap: anywhere;
    min-width: 0;
    margin: 0 0 0.5rem;
  }

  .hero__subtitle {
    font-family: var(--blume-font-display);
    font-weight: 500;
    letter-spacing: -0.015em;
    line-height: 1.3;
    font-size: clamp(0.95rem, 1.2vw + 0.55rem, 1.15rem);
    margin: 0 0 0.75rem;
    color: var(--blume-muted-foreground);
    max-width: 32ch;
  }

  .hero__lede {
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--blume-muted-foreground);
    margin: 0 0 1.1rem;
    max-width: 42ch;
  }

  .hero__note {
    margin: 0.85rem 0 0;
    font-family: var(--blume-font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.02em;
    color: var(--blume-muted-foreground);
  }

  .hero__note em {
    font-style: italic;
  }

  .hero__note a {
    color: var(--blume-accent);
    text-decoration: none;
  }

  .hero__note a:hover {
    text-decoration: underline;
  }

  .hero__ctas {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .hero__demo {
    min-width: 0;
  }

  /* keep terminal from forcing scroll on short viewports */
  .hero__demo :global(pre) {
    max-height: min(42vh, 18rem);
    overflow: auto;
    font-size: 0.78rem !important;
    line-height: 1.4 !important;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--blume-radius);
    padding: 0.55rem 1rem;
    font-weight: 500;
    font-size: 0.9rem;
    text-decoration: none;
    white-space: nowrap;
    transition:
      transform 160ms var(--home-ease-out),
      background-color 160ms var(--home-ease-out),
      border-color 160ms var(--home-ease-out);
  }

  .btn:active {
    transform: scale(0.97);
  }

  .btn--primary {
    background: var(--blume-accent);
    color: var(--blume-accent-foreground);
    border: 1px solid var(--blume-accent);
  }

  @media (hover: hover) and (pointer: fine) {
    .btn--primary:hover {
      background: color-mix(in oklch, var(--blume-accent), black 8%);
    }
  }

  .btn--ghost {
    background: transparent;
    color: var(--blume-foreground);
    border: 1px solid var(--blume-border);
  }

  @media (hover: hover) and (pointer: fine) {
    .btn--ghost:hover {
      border-color: var(--blume-accent);
      color: var(--blume-accent);
    }
  }

  .reveal {
    animation: home-reveal 600ms var(--home-ease-out) both;
  }

  @keyframes home-reveal {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reveal {
      animation: none;
    }
  }

  /* compact site footer on home only */
  :global(.home-footer) {
    padding-block: 0.75rem !important;
  }
</style>
