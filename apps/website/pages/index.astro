---
// Hallmark · genre: modern-minimal · macrostructure: Workbench · theme: Cobalt
// nav: Blume's real Header (restyled via Cobalt tokens, not hand-rolled — no fake chrome)
// footer: Ft2 inline · enrichment: code/terminal-hero (real `dora` output, nothing invented)
import PageLayout from "blume/components/layout/PageLayout.astro";
import CodeBlock from "blume/components/content/CodeBlock.astro";
import data from "blume:data";
import Footer from "./_home/Footer.astro";

const { config } = data;

const scanOutput = `$ dora

  doraval v0.6.x
  Read-only scan of agent context — no writes, no LLM.

  Agent surfaces
    ✓ claude    CLAUDE.md  .claude/skills
    ⚠ cursor    not configured

  Health
    ✓ .claude/skills/review    valid
    ✗ .claude/skills/deploy    Missing "description"

  Next
    1. dora fix .claude/skills/deploy
    2. dora review --all`;

const installCmd = `# one-shot (no install)
npx @hacksmith/doraval

# or install once, then use dora / doraval
npm install -g @hacksmith/doraval
# brew tap saif-shines/tap && brew trust saif-shines/tap && brew install doraval
# bun add -g @hacksmith/doraval

dora`;

const loopPrompt = `Install doraval if needed, then run the doraval loop in this repo:
1. dora (scan) — fix anything it suggests
2. dora review . then dora fix . (use --yes for mechanical fixes)
3. dora memory add any project principles we should keep
Use --format json / --ci when you need machine output. Prefer dora new --for <agent> over hand-writing skill files.`;

const agentCmds = `dora                                          # scan
dora new skill --for claude --name review-pr --description "Reviews PRs" --yes
dora review .                                 # structure + heuristics (+ LLM when available)
dora fix .                                    # diffs first; asks before writing
dora memory add "Run tests before shipping skill changes" --weight 8`;
---

<PageLayout
  site={{ title: config.title, description: config.description }}
  logo={config.logo}
  favicon={config.favicon}
  banner={config.banner}
  analytics={config.analytics}
  navigation={data.navigation}
  fontCssVars={data.fontCssVars}
  themeMode={config.theme.mode}
  searchEnabled={config.search.enabled}
  siteUrl={config.site}
  ogEnabled={config.og.enabled}
  page={{
    title: `${config.title} — ${config.description}`,
    description: config.description,
    route: "/",
  }}
>
  <div class="home">
    <section class="hero">
      <div class="hero__copy reveal">
        <p class="home-eyebrow">DORAVAL · THE `dora` CLI</p>
        <h1 class="hero__title">Scale your AI context for coding agents</h1>
        <p class="hero__lede">
          <strong>doraval</strong> (<em>dor-uh-val</em>) = <strong>Doraemon</strong
          > + <strong>eval</strong>. Context you cannot trust wastes a day —
          doraval makes the first attempt succeed, across Claude, Cursor,
          Codex, Copilot, and Grok.
        </p>
        <div class="hero__ctas">
          <a class="btn btn--primary" href="/get-started/">Get started</a>
          <a class="btn btn--ghost" href="/for-agents/">For coding agents</a>
        </div>
      </div>
      <div class="hero__demo reveal">
        <CodeBlock code={scanOutput} lang="text" title="dora" />
      </div>
    </section>

    <section class="band band--light reveal">
      <p class="home-eyebrow">FIRST WIN</p>
      <p class="section__lede">
        Zero config. No API key. <a href="/get-started/installation/"
          >Full install options</a
        > (npm, Homebrew, Bun, <code>npx</code> / <code>bunx</code>).
      </p>
      <CodeBlock code={installCmd} lang="bash" title="terminal" />
      <p class="home-caption">
        Scan and session analysis span all five agents. Scaffolding and
        packaging review cover Claude, Cursor, Codex, and Copilot; the LLM
        judge runs on a Claude or Grok CLI you already have — or any API key.
      </p>
    </section>

    <section class="band band--payoff reveal">
      <p class="home-eyebrow">WHY THE FIRST TRY WORKS</p>
      <div class="payoff">
        <div class="payoff__item">
          <h3 class="payoff__title">Principles become tests</h3>
          <p class="payoff__body">
            <code>dora memory</code> records a rule once. Review enforces it —
            a principle weighted 7+ fails as an <strong>error</strong>, not a
            polite warning.
          </p>
        </div>
        <div class="payoff__item">
          <h3 class="payoff__title">Cross-agent conflicts, settled</h3>
          <p class="payoff__body">
            <code>dora reconcile</code> finds where Claude and Cursor
            contradict each other and writes the resolution into a shared
            <code>AGENTS.md</code> — no LLM required.
          </p>
        </div>
        <div class="payoff__item">
          <h3 class="payoff__title">Skills that phone home, flagged</h3>
          <p class="payoff__body">
            Review scans a skill's <code>scripts/</code> for outbound calls and
            secret prompts before it ever runs in an agent.
          </p>
        </div>
      </div>
    </section>

    <section class="band band--dark reveal">
      <p class="home-eyebrow home-eyebrow--dark">THE LOOP</p>
      <h2 class="section__title section__title--dark">
        Let your coding agent drive it
      </h2>
      <p class="section__lede section__lede--dark">
        Point Claude, Cursor, Codex, Copilot, or Grok at the repo and paste
        this — JSON-friendly flags are built in.
      </p>
      <div class="band__grid">
        <div class="code-shell">
          <CodeBlock code={loopPrompt} lang="text" title="prompt" />
        </div>
        <div class="code-shell">
          <CodeBlock code={agentCmds} lang="bash" title="what the agent runs" />
        </div>
      </div>
    </section>

    <section class="band band--light reveal next">
      <div class="next__example">
        <p class="home-eyebrow">DETAILS</p>
        <p class="section__lede">
          Full reference for scan, review, fix, new, memory, and more — plus
          JSON mode, CI, and exit codes for agents.
        </p>
      </div>
      <nav class="next__links" aria-label="Next steps">
        <a href="/get-started/">Get started →</a>
        <a href="/commands/scan/">Commands →</a>
        <a href="/for-agents/">For coding agents →</a>
      </nav>
    </section>
  </div>

  <Footer slot="footer" title={config.title} description={config.description} />
</PageLayout>

<style>
