# Z.AI API key for direct eval judge
ZAI_API_KEY=your-zai-api-key-here

# We default glm* models to the general Z.AI endpoint.
# You don't need to specify your plan.
# Override the base URL if you use a different endpoint (e.g. Coding Plan, proxy, LiteLLM):
# OPENAI_BASE_URL=https://api.z.ai/api/coding/paas/v4
# ZAI_BASE_URL=https://api.z.ai/api/coding/paas/v4   # also supported (ZAI_* naming)

# PostHog analytics (used by src/analytics.ts).
# POSTHOG_API_KEY can be left empty to disable event capture.
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
