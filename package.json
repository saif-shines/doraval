{
  "name": "doraval",
  "version": "0.0.1",
  "description": "Validate, score, and test skills and plugins for AI coding agents",
  "type": "module",
  "bin": {
    "doraval": "./bin/doraval.js"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "bun build ./src/cli/index.ts --outfile ./bin/doraval.js --target node --format esm",
    "dev": "bun run ./src/cli/index.ts",
    "test": "bun test"
  },
  "keywords": [
    "cli",
    "skills",
    "plugins",
    "agent",
    "validation",
    "lint",
    "claude-code",
    "grok",
    "cursor",
    "windsurf",
    "mcp"
  ],
  "author": "Saif",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/saif-shines/doraval.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "gray-matter": "^4.0.3",
    "zod": "^4.4.3"
  }
}
